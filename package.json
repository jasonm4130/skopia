{
  "name": "stratus",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "packageManager": "pnpm@11.0.8",
  "scripts": {
    "dev": "wrangler dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.script.json",
    "build": "pnpm build:schema && pnpm build:script",
    "build:schema": "node scripts/build-schema.mjs",
    "build:script": "node scripts/build-script.mjs && node scripts/build-embed.mjs",
    "build:embed": "node scripts/build-embed.mjs",
    "fetch-vendor": "node scripts/fetch-vendor.mjs",
    "check:size": "node scripts/check-script-size.mjs",
    "check:cookieless": "node scripts/check-cookieless.mjs",
    "check:no-external": "node scripts/check-no-external.mjs",
    "ci": "pnpm typecheck && pnpm test && pnpm build:schema && pnpm build:script && pnpm check:size && pnpm check:cookieless && pnpm check:no-external"
  },
  "cloudflare": {
    "bindings": {
      "AUTH_COOKIE_SECRET":   { "description": "Session signing key. Generate: openssl rand -hex 32" },
      "IDENTITY_HMAC_SECRET": { "description": "Cookieless visitor-hash key. Generate: openssl rand -hex 32" },
      "CF_ACCOUNT_ID":        { "description": "Your Cloudflare account ID (Workers → Account ID)." },
      "WAE_API_TOKEN":        { "description": "API token with Account Analytics: Read, for dashboard queries." }
    }
  },
  "dependencies": {
    "hono": "^4.12.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.18",
    "@cloudflare/workers-types": "^4.20260621.1",
    "esbuild": "^0.28.1",
    "typescript": "~5.7.3",
    "vitest": "~4.1.9",
    "wrangler": "^4.103.0"
  }
}
