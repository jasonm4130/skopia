{
  "name": "stratus",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "dev": "wrangler dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.script.json",
    "build:script": "esbuild src/script/stratus.ts --bundle --minify --format=iife --outfile=dist/stratus.js && node scripts/build-embed.mjs",
    "build:embed": "node scripts/build-embed.mjs",
    "check:size": "node scripts/check-script-size.mjs",
    "check:cookieless": "node scripts/check-cookieless.mjs",
    "ci": "npm run typecheck && npm run test && npm run build:script && npm run check:size && npm run check:cookieless"
  },
  "dependencies": {
    "hono": "^4.12.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.18",
    "@cloudflare/workers-types": "^4.20260621.1",
    "esbuild": "^0.28.1",
    "typescript": "~5.7.3",
    "vitest": "~4.1.9",
    "wrangler": "^4.103.0"
  }
}
